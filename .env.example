# Example environment file for Render.com deployment
# Copy this to .env and fill in your actual values

# Database Configuration
DB_HOST=qloapps-mysql.render.internal
DB_PORT=3306
DB_NAME=qloapps
DB_USER=qloapps
DB_PASSWORD=your_secure_password_here

# App Configuration
APP_ENV=production
APP_DEBUG=false
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=16M
PHP_POST_MAX_SIZE=16M

# Optional: Website configuration
WEBSITE_NAME=QloApps Hotel Booking
WEBSITE_LANGUAGE=en
